      "parameters": {
        "jsCode": "const questions = $input.first().json.data;\n\nlet formHTML = `<form method=\"POST\" action=\"https://ramyarrr987.app.n8n.cloud/webhook/158d1c54-db0e-486d-8d47-bcf3ce231e96\">`;\n\nquestions.forEach((q, i) => {\n  formHTML += `\n  <div>\n    <label>Question ${i+1}: ${q.Question}</label><br>\n    <input type=\"text\" name=\"Answer${i+1}\" placeholder=\"Your answer...\">\n    <input type=\"hidden\" name=\"Reference${i+1}\" value=\"${q.Reference}\">\n    <input type=\"hidden\" name=\"idnum${i+1}\" value=\"${q.idnum}\">\n  </div>\n  <br><br>\n  `;\n});\n\nformHTML += `\n  <button type=\"submit\">Submit</button>\n</form>`;\n\nreturn [{ json: { formHTML } }];"
      },
