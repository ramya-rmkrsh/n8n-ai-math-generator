    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate {{ $json.num1 }} math questions from {{$json.Syllabus}} {{$json.Topic1}}.\n\nReturn ONLY valid JSON in this format:\n\n{\n \"questions\": [\n  {\"question\":\"...\",\"answer\":\"...\"},\n  {\"question\":\"...\",\"answer\":\"...\"},\n  {\"question\":\"...\",\"answer\":\"...\"},\n  {\"question\":\"...\",\"answer\":\"...\"},\n  {\"question\":\"...\",\"answer\":\"...\"}\n ]\n}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a helpful assistant who generates maths questions for school children. "
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        400,
        -480
      ],
      "id": "07aad8ea-3572-4294-9bd5-233f4d5ae337",
      "name": "Generate Maths Questions and Answers",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.body;\n\nlet total = 0;\nlet results = {};\nlet i = 1;\n\nwhile (data[`Reference${i}`] !== undefined) {\n  const studentAnswer = String(data[`Answer${i}`] || '');\n  const correctAnswer = String(data[`Reference${i}`] || '');\n  const answerid = String(data[`idnum${i}`] || '');\n\n  // Extract all numbers from both answers\n  const studentNums = studentAnswer.match(/\\d+(\\.\\d+)?/g)?.map(Number).sort((a,b) => a-b) || [];\n  const correctNums = correctAnswer.match(/\\d+(\\.\\d+)?/g)?.map(Number).sort((a,b) => a-b) || [];\n  \n\n  // Check if both arrays contain the same numbers\n  const isCorrect = \n    studentNums.length > 0 &&\n    studentNums.length === correctNums.length &&\n    studentNums.every((n, idx) => n === correctNums[idx]);\n\n  if (isCorrect) total++;\n\n  results[`Question${i}`] = {\n    studentAnswer,\n    correctAnswer,\n    mark: isCorrect ? 1 : 0,\n    id: answerid\n  };\n\n  i++;\n}\n\nreturn [{ json: { total, outOf: i - 1, results } }];"
      },
      "id": "b8f35b46-163b-4aa0-9a6f-adda3707425b",
      "name": "Assess Form Answers ",
